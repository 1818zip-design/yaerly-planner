{
  "functions": {
    "api/telegram-webhook.ts": {
      "maxDuration": 60
    },
    "api/daily-reminder.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/daily-reminder",
      "schedule": "0 14 * * *"
    }
  ]
}
